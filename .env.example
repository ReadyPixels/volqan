# =============================================================================
# Volqan — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/volqan?schema=public"

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Secret used to sign session tokens — must be long, random, and kept private
SESSION_SECRET="change-me-to-a-long-random-string-in-production"

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Public URL of the admin panel (used for OAuth redirects and email links)
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# ---------------------------------------------------------------------------
# File uploads
# ---------------------------------------------------------------------------
# Absolute or relative path where uploaded media files are stored
# In Docker, mount a volume at this path
VOLQAN_UPLOAD_DIR="./public/uploads"

# ---------------------------------------------------------------------------
# Stripe (billing — optional, required for Support Plan subscriptions)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_PRICE_YEARLY=""
STRIPE_PRICE_MONTHLY=""
STRIPE_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# OAuth (optional — routes not yet implemented)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# License & cron
# ---------------------------------------------------------------------------
LICENSE_SECRET=""
CRON_SECRET=""

# ---------------------------------------------------------------------------
# Redis (optional — in-process LRU fallback used when unset)
# ---------------------------------------------------------------------------
REDIS_URL=""

# ---------------------------------------------------------------------------
# Email (optional — console fallback used in development)
# Set EMAIL_TRANSPORT=resend and provide RESEND_API_KEY to send real emails.
# ---------------------------------------------------------------------------
EMAIL_TRANSPORT="console"
EMAIL_FROM="Volqan <noreply@volqan.link>"
RESEND_API_KEY=""

# ---------------------------------------------------------------------------
# Bazarix marketplace (optional)
# ---------------------------------------------------------------------------
BAZARIX_LICENSE_KEY=""
