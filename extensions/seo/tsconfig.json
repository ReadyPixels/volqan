{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "typeRoots": ["../../node_modules/@types", "./node_modules/@types"],
    "paths": {
      "@volqan/core": ["../packages/core/dist/index.js"],
      "@volqan/core/*": ["../packages/core/dist/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
